{
  "name": "portfolio_surf",
  "version": "1.5.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint app components lib scripts tests middleware.ts next.config.ts open-next.config.ts eslint.config.mjs postcss.config.mjs",
    "test:blog": "node --import tsx --test tests/blog.test.ts",
    "cf:build": "opennextjs-cloudflare build",
    "preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "deploy": "opennextjs-cloudflare build && NODE_OPTIONS=--dns-result-order=ipv4first opennextjs-cloudflare deploy",
    "upload": "opennextjs-cloudflare build && NODE_OPTIONS=--dns-result-order=ipv4first opennextjs-cloudflare upload",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts",
    "update-apk": "node scripts/update-apk.mjs",
    "postdeploy": "node scripts/submit-indexnow.mjs"
  },
  "dependencies": {
    "@opennextjs/cloudflare": "^1.19.11",
    "framer-motion": "^12.23.24",
    "github-slugger": "^2.0.0",
    "gray-matter": "^4.0.3",
    "mdast-util-to-string": "^4.0.0",
    "next": "^16.2.9",
    "next-mdx-remote": "^6.0.0",
    "opentype.js": "^1.3.4",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "reading-time": "^1.5.0",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-slug": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.1.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "^16.2.9",
    "tailwindcss": "^4",
    "tsx": "^4.23.0",
    "typescript": "^5",
    "wrangler": "^4.104.0"
  }
}
