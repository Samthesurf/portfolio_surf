{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "samuelsurf-opennext",
  "main": ".open-next/worker.js",
  "workers_dev": true,
  "compatibility_date": "2026-06-23",
  "compatibility_flags": [
    "nodejs_compat",
    "global_fetch_strictly_public"
  ],
  "assets": {
    "directory": ".open-next/assets",
    "binding": "ASSETS"
  },
  "services": [
    {
      "binding": "WORKER_SELF_REFERENCE",
      "service": "samuelsurf-opennext"
    }
  ],
  "images": {
    "binding": "IMAGES"
  },
  "r2_buckets": [
    {
      "binding": "BLOG_CONTENT",
      "bucket_name": "samuelsurf-content"
    }
  ],
  "vars": {
    "STUDIO_ALLOWED_EMAIL": "ukpsamuel67@gmail.com"
  },
  "observability": {
    "enabled": true,
    "head_sampling_rate": 1
  },
  "routes": [
    {
      "pattern": "samuelsurf.me/*",
      "zone_name": "samuelsurf.me"
    },
    {
      "pattern": "www.samuelsurf.me/*",
      "zone_name": "samuelsurf.me"
    },
    {
      "pattern": "write.samuelsurf.me",
      "custom_domain": true
    }
  ]
}
